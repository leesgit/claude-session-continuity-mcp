{
  "name": "passbaton",
  "version": "2.1.2",
  "description": "Session continuity and persistent memory for Claude Code, OpenAI Codex CLI & Google Gemini CLI. Auto-injects past context on start, hands over hot files + build status across compaction, shares one local db across all three. Every feature is opt-in via `passbaton config`. 100% local SQLite, zero API cost.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "passbaton": "dist/index.js",
    "passbaton-hooks": "dist/hooks/install.js",
    "passbaton-hook-session-start": "dist/hooks/session-start.js",
    "passbaton-hook-user-prompt": "dist/hooks/user-prompt-submit.js",
    "passbaton-hook-post-tool": "dist/hooks/post-tool-use.js",
    "passbaton-hook-pre-compact": "dist/hooks/pre-compact.js",
    "passbaton-hook-session-end": "dist/hooks/session-end.js",
    "claude-session-continuity-mcp": "dist/index.js",
    "claude-session-hooks": "dist/hooks/install.js",
    "claude-hook-session-start": "dist/hooks/session-start.js",
    "claude-hook-user-prompt": "dist/hooks/user-prompt-submit.js",
    "claude-hook-post-tool": "dist/hooks/post-tool-use.js",
    "claude-hook-pre-compact": "dist/hooks/pre-compact.js",
    "claude-hook-session-end": "dist/hooks/session-end.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:v2": "MCP_V2_ONLY=true node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node dist/hooks/install.js install 2>/dev/null || true",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "claude-code-memory",
    "claude-code-hooks",
    "codex",
    "codex-cli",
    "openai",
    "gemini",
    "gemini-cli",
    "google",
    "ai",
    "context",
    "memory",
    "session",
    "continuity",
    "session-continuity",
    "session-memory",
    "persistent-memory",
    "agent-memory",
    "coding-agent",
    "ai-agent",
    "compaction",
    "context-injection",
    "local-first",
    "sqlite",
    "anthropic",
    "passbaton"
  ],
  "author": "Byeongchang Lee <leesgit@github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leesgit/passbaton.git"
  },
  "bugs": {
    "url": "https://github.com/leesgit/passbaton/issues"
  },
  "homepage": "https://github.com/leesgit/passbaton#readme",
  "files": [
    "dist",
    "dist/hooks",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@xenova/transformers": "^2.17.0",
    "better-sqlite3": "^12.11.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
